// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "active_pane_modifiers": {
    "inactive_opacity": 0.9,
    "border_size": 2.0,
  },
  "edit_predictions": {
    "allow_data_collection": "no",
    "provider": "copilot",
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
    "claude-acp": {
      "favorite_config_option_values": {
        "model": [
          "sonnet"
        ]
      },
      "default_config_options": {
        "model": "sonnet",
        "mode": "bypassPermissions",
      },
      "type": "registry",
      "default_mode": "bypassPermissions",
    },
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "icon_theme": "Catppuccin Mocha",
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "tool_permissions": {
      "default": "confirm",
      "tools": {},
    },
    "show_turn_stats": true,
    "play_sound_when_agent_done": "always",
    "inline_assistant_model": {
      "provider": "copilot",
      "model": "claude-4.5-sonnet",
    },
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "gpt-5.3-codex",
    },
    "default_profile": "write",
  },
  "base_keymap": "VSCode",
  "autosave": {
    "after_delay": {
      "milliseconds": 100,
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha - No Italics",
  },
  "vim_mode": true,
  "vim": {
    // "always": use system clipboard when no register is specified
    // "never": don't use system clipboard unless "+ or "* is specified
    // "on_yank": use system clipboard for yank operations when no register is specified
    "use_system_clipboard": "always",
    // Let `f` and `t` motions match case insensitively if the target is lowercase
    "use_smartcase_find": true,
    // Use relative line numbers in normal mode, absolute in insert mode
    // c.f. https://github.com/jeffkreeftmeijer/vim-numbertoggle
    "toggle_relative_line_numbers": true,
    "custom_digraphs": {
      "fz": "🧟‍♀️",
    },
  },
  "relative_line_numbers": "enabled",
  "cursor_blink": false,
  "scroll_beyond_last_line": "off",
  "ui_font_size": 13,
  "buffer_font_size": 13,
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "show_whitespaces": "boundary",
  "terminal": {
    "font_family": "MesloLGS NF",
  },
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "languages": {
    "Python": {
      "language_servers": ["pyright", "ruff", "!pylsp"],
      "format_on_save": "on",
      "formatter": [
        {
          "code_action": "source.organizeImports.ruff",
        },
        {
          "code_action": "source.fixAll.ruff",
        },
        {
          "language_server": {
            "name": "ruff",
          },
        },
      ],
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "maxLength": 25,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "typeHints": {
            "enable": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
      },
    },
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "changelog/*",
    "node_modules/*",
  ],
  "minimap": {
    "show": "auto",
    "thumb": "always",
    "thumb_border": "full",
    "current_line_highlight": null,
  },
}
